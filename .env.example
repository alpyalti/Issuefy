# ───────────────────────────────────────────────────────────────
# Issuefy — environment variables (copy to .env.local and fill in)
# ───────────────────────────────────────────────────────────────

# App URL (used by the cron dispatcher to fetch the worker route with an absolute URL)
APP_URL=http://localhost:3000

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Neon (Postgres)
DATABASE_URL=

# Cloudflare R2 (optional — raw HTML archival only)
R2_ENABLED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ScraperAPI
SCRAPERAPI_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL_PRIMARY=google/gemini-2.0-flash-001
OPENROUTER_MODEL_FALLBACK=openai/gpt-4o-mini

# Apify (Competitor Hub — Instagram profile tracking). Optional: when unset,
# Instagram fetches are silently skipped; YouTube/Reddit/LinkedIn stats still work.
APIFY_TOKEN=
# Override the actor if needed (tilde form). Default: apify~instagram-profile-scraper
# APIFY_IG_ACTOR=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Issuefy <hello@issuefy.app>

# Where inbound support ticket notifications go (optional — falls back to support@issuefy.app
# with a Sentry breadcrumb on missing env).
SUPPORT_INBOX_EMAIL=

# Stripe (billing — required in prod, leave blank locally to disable the trial gate)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cron / internal worker secrets
CRON_SECRET=
INTERNAL_WORKER_SECRET=

# Beta-mode flag — when "true" everyone gets Starter limits regardless of their plan column.
# Default "false" once billing is in production.
BETA_STARTER_LIMITS=false

# Sentry (optional — no-ops if unset)
SENTRY_DSN=
